---
import Layout from '../../components/Layout.astro';
import Tag from '../../components/Tag.astro';
import { data, termMaps, withBase } from '../../lib/data';
const domains = data.taxonomies.domains.filter((term) => data.benchmarks.some((b) => b.domains.includes(term.id)));
const access = data.taxonomies.access_levels;
const kinds = [...new Set(data.benchmarks.map((b) => b.kind))].sort();
const tasks = data.scientific_tasks.filter((task) => data.scientific_task_coverage.some((row) => row.task_type_id === task.id));
const benchmarkRows = data.benchmarks.map((benchmark) => {
  const taskIds = benchmark.scientific_task_classification.entries.map((entry) => entry.task_type_id);
  const search = `${benchmark.name} ${benchmark.aliases.join(' ')} ${benchmark.summary} ${benchmark.domains.map((id) => termMaps.domains.get(id)?.label).join(' ')} ${taskIds.flatMap((id) => {
    const term = data.scientific_tasks.find((item) => item.id === id);
    return term ? [term.label, ...term.aliases] : [id];
  }).join(' ')}`.toLowerCase();
  return { benchmark, taskIds, search };
});
---
<Layout title="Benchmark Explorer" canonicalPath="/benchmarks/">
  <header class="page-head page-head--compact shell"><p class="eyebrow">Registry explorer</p><h1>Benchmarks, with the evaluation context attached.</h1><p class="lede">Search the scientific scope, filter access and task type, then inspect every work and run behind an entry. Filters persist in the URL.</p></header>
  <div class="shell section-tight">
    <form class="explorer-form" id="explorer-controls" role="search">
      <div class="explorer-controls explorer-controls--benchmarks">
        <div class="field"><label for="q">Search</label><input id="q" name="q" type="search" placeholder="protein design, single-cell, binding…" /></div>
        <div class="field"><label for="domain">Domain</label><select id="domain" name="domain"><option value="">All domains</option>{domains.map((term) => <option value={term.id}>{term.label}</option>)}</select></div>
        <div class="field"><label for="task">Scientific task</label><select id="task" name="task"><option value="">All scientific tasks</option>{tasks.map((term) => <option value={term.id}>{term.label}</option>)}</select></div>
      </div>
      <details class="advanced-filters" data-advanced-filter>
        <summary>Advanced filters <span data-advanced-count></span></summary>
        <div class="explorer-controls advanced-controls">
          <div class="field"><label for="access">Access</label><select id="access" name="access"><option value="">All access</option>{access.map((term) => <option value={term.id}>{term.label}</option>)}</select></div>
          <div class="field"><label for="kind">Kind</label><select id="kind" name="kind"><option value="">All kinds</option>{kinds.map((kind) => <option value={kind}>{kind}</option>)}</select></div>
        </div>
      </details>
    </form>
    <p class="small muted"><strong id="visible-count">{data.benchmarks.length}</strong> records · <a href={withBase('/data/benchmarks.csv')} download>Download all benchmarks CSV</a></p>
    <div class="table-wrap desktop-record-table">
      <table id="benchmark-table">
        <thead><tr><th>Benchmark</th><th>Kind / release</th><th>Domain</th><th>Scientific task</th><th>Access</th><th>Runs</th></tr></thead>
        <tbody>{benchmarkRows.map(({ benchmark, taskIds, search }) => <tr data-record-id={benchmark.id} data-search={search} data-domains={benchmark.domains.join(' ')} data-tasks={taskIds.join(' ')} data-access={benchmark.access.level} data-kind={benchmark.kind}>
          <td><a href={withBase(`/benchmarks/${benchmark.id}/`)}>{benchmark.name}</a><br/><span class="muted small">{benchmark.summary}</span></td>
          <td>{benchmark.kind}<br/><span class="muted">{benchmark.release_date}</span></td>
          <td><div class="tag-list">{benchmark.domains.slice(0, 3).map((id) => <Tag id={id} />)}{benchmark.domains.length > 3 && <span class="tag">+{benchmark.domains.length - 3}</span>}</div></td>
          <td><div class="tag-list">{taskIds.slice(0, 2).map((id) => <Tag id={id} axis="scientific_tasks" linked />)}{taskIds.length > 2 && <span class="tag">+{taskIds.length - 2}</span>}{taskIds.length === 0 && <span class="not-reported">Unclassified</span>}</div></td>
          <td><span class:list={['tag', {'accent': benchmark.access.level === 'fully-open', 'warn': benchmark.access.level === 'private-internal'}]}>{termMaps.access_levels.get(benchmark.access.level)?.label ?? benchmark.access.level}</span></td>
          <td>{benchmark.evaluation_run_ids.length}</td>
        </tr>)}</tbody>
      </table>
    </div>
    <div class="mobile-records" data-mobile-records>
      {benchmarkRows.map(({ benchmark, taskIds, search }) => <article class="record-card" data-mobile-record data-record-id={benchmark.id} data-search={search} data-domains={benchmark.domains.join(' ')} data-tasks={taskIds.join(' ')} data-access={benchmark.access.level} data-kind={benchmark.kind}>
        <h2><a href={withBase(`/benchmarks/${benchmark.id}/`)}>{benchmark.name}</a></h2>
        <p class="small muted">{benchmark.summary}</p>
        <div class="record-meta"><span>{benchmark.kind}</span><span>{benchmark.release_date}</span><span class:list={['tag', {'accent': benchmark.access.level === 'fully-open', 'warn': benchmark.access.level === 'private-internal'}]}>{termMaps.access_levels.get(benchmark.access.level)?.label ?? benchmark.access.level}</span></div>
        <div class="tag-list">{benchmark.domains.slice(0, 2).map((id) => <Tag id={id} />)}{benchmark.domains.length > 2 && <span class="tag">+{benchmark.domains.length - 2}</span>}</div>
        <div class="tag-list" style="margin-top:.4rem">{taskIds.slice(0, 2).map((id) => <Tag id={id} axis="scientific_tasks" linked />)}{taskIds.length > 2 && <span class="tag">+{taskIds.length - 2}</span>}{taskIds.length === 0 && <span class="not-reported small">Unclassified</span>}</div>
        <div class="record-stats"><div><small>Evaluation runs</small><strong>{benchmark.evaluation_run_ids.length}</strong></div><div><small>Latest version</small><strong>{benchmark.latest_version}</strong></div></div>
      </article>)}
    </div>
    <p id="no-results" class="callout" hidden>No benchmark matches this combination. The URL still preserves your filters.</p>
  </div>
  <script>
    const form = document.querySelector<HTMLFormElement>('#explorer-controls')!;
    const rows = [...document.querySelectorAll<HTMLTableRowElement>('#benchmark-table tbody tr')];
    const cards = new Map([...document.querySelectorAll<HTMLElement>('[data-mobile-record]')].map((card) => [card.dataset.recordId, card]));
    const count = document.querySelector<HTMLElement>('#visible-count')!;
    const empty = document.querySelector<HTMLElement>('#no-results')!;
    const advanced = form.querySelector<HTMLDetailsElement>('[data-advanced-filter]')!;
    const advancedCount = advanced.querySelector<HTMLElement>('[data-advanced-count]')!;
    const params = new URLSearchParams(location.search);
    for (const name of ['q', 'domain', 'access', 'kind', 'task']) {
      const control = form.elements.namedItem(name) as HTMLInputElement | HTMLSelectElement;
      control.value = params.get(name) ?? '';
    }
    advanced.open = ['access', 'kind'].some((name) => Boolean(params.get(name)));
    function update() {
      const values = Object.fromEntries(new FormData(form)) as Record<string, string>;
      let visible = 0;
      rows.forEach((row) => {
        const match = (!values.q || row.dataset.search?.includes(values.q.toLowerCase())) && (!values.domain || row.dataset.domains?.split(' ').includes(values.domain)) && (!values.access || row.dataset.access === values.access) && (!values.kind || row.dataset.kind === values.kind) && (!values.task || row.dataset.tasks?.split(' ').includes(values.task));
        row.hidden = !match;
        const card = cards.get(row.dataset.recordId);
        if (card) card.hidden = !match;
        if (match) visible += 1;
      });
      const activeAdvanced = ['access', 'kind'].filter((name) => values[name]).length;
      advancedCount.textContent = activeAdvanced ? `(${activeAdvanced})` : '';
      count.textContent = String(visible);
      empty.hidden = visible !== 0;
      const next = new URLSearchParams();
      Object.entries(values).forEach(([key, value]) => value && next.set(key, value));
      history.replaceState(null, '', `${location.pathname}${next.size ? `?${next}` : ''}`);
    }
    form.addEventListener('input', update);
    update();
  </script>
</Layout>
