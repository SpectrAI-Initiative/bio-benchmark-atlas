---
import Layout from '../../components/Layout.astro';
import PlotCard from '../../components/PlotCard.astro';
import RunCard from '../../components/RunCard.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import Tag from '../../components/Tag.astro';
import { aliasSlug, benchmarkMap, data, evidenceLocator, evidenceSourceId, fieldStatus, modelMap, runMap, termMaps, withBase, workMap } from '../../lib/data';

export function getStaticPaths() {
  return data.benchmarks.flatMap((benchmark) => [
    { params: { id: benchmark.id }, props: { benchmark, alias: false } },
    ...benchmark.aliases.map((alias) => ({ params: { id: aliasSlug(alias) }, props: { benchmark, alias: true } })),
  ]);
}
const { benchmark, alias } = Astro.props;
if (!benchmark) return Astro.redirect(withBase('/404/'));
const parent = benchmark.parent_id ? benchmarkMap.get(benchmark.parent_id) : undefined;
const children = data.benchmarks.filter((item) => item.parent_id === benchmark.id);
const childRunCount = children.reduce((total, child) => total + child.evaluation_run_ids.length, 0);
const includeChildRuns = children.length <= 10;
const runIds = [...benchmark.evaluation_run_ids, ...(includeChildRuns ? children.flatMap((child) => child.evaluation_run_ids) : [])];
const runs = [...new Set(runIds)].map((id: string) => runMap.get(id)).filter(Boolean);
const statusFor = (path: string) => fieldStatus(benchmark, path);
const taskClassification = benchmark.scientific_task_classification;
const resultCharts = runs.flatMap((run) => run!.metrics.map((metric) => ({
  run: run!, metric,
  values: run!.results
    .filter((r) => r.metric_id === metric.metric_id && (r.status === undefined || r.status === 'verified'))
    .map((r) => ({ label: modelMap.get(r.model_id)?.name ?? r.model_id, value: r.value, group: run!.comparability_group })),
}))).filter((chart) => chart.values.length > 0);
---
{alias ? (
  <Layout title={`Redirecting to ${benchmark.name}`} canonicalPath={`/benchmarks/${benchmark.id}/`}>
    <div class="narrow section"><h1>Moved permanently</h1><p>This alias now points to <a href={withBase(`/benchmarks/${benchmark.id}/`)}>{benchmark.name}</a>.</p></div>
    <script is:inline define:vars={{ target: withBase(`/benchmarks/${benchmark.id}/`) }}>location.replace(target);</script>
  </Layout>
) : (
  <Layout title={benchmark.name} description={benchmark.summary} canonicalPath={`/benchmarks/${benchmark.id}/`}>
    <header class="page-head shell">
      <div class="breadcrumbs"><a href={withBase('/benchmarks/')}>Benchmarks</a><span>/</span>{parent && <><a href={withBase(`/benchmarks/${parent.id}/`)}>{parent.name}</a><span>/</span></>}<span>{benchmark.name}</span></div>
      <p class="eyebrow">{benchmark.kind} · {benchmark.audit.status} · verified {benchmark.verification.last_verified}</p>
      <h1>{benchmark.name}</h1><p class="lede">{benchmark.summary}</p>
      <div class="tag-list">{benchmark.domains.map((id) => <Tag id={id} linked accent />)}</div>
    </header>
    <div class="shell section detail-grid">
      <div>
        {benchmark.audit.status === 'legacy' ? <div class="callout info"><strong>Legacy record:</strong> this entry has not yet completed the v1.1 field-level audit. Existing values remain visible but do not carry the stronger audited claim.</div> : benchmark.field_status.length > 0 && <div class="callout"><strong>Audited with caveats:</strong> {benchmark.field_status.length} field(s) are marked provisional or conflicted. Warnings are shown next to affected values and these claims are excluded from unqualified comparisons.</div>}
        {benchmark.id === 'lifescibench' && <div class="callout"><strong>Protein & binding audit:</strong> 136 tasks use Protein and Structural Biology as the primary domain; 62 are in Design, Optimization & Prediction. Protein binding is explicitly in scope, but its standalone task count is <strong>Not reported</strong>.</div>}
        {benchmark.id === 'proteingym' && <div class="callout"><strong>Version and binding audit:</strong> v1.0 reports 14 generic Binding substitution assays; the v1.1–v1.3 reference files contain 13. The v1.3 release archive contains 66 DMS indel assay records while its pinned README says 74, so the current count remains <strong>Conflicted</strong>.</div>}
        {benchmark.id === 'casp' && <div class="callout"><strong>Round and count audit:</strong> CASP17 is an active, rolling 2026 round; all displayed CASP17 counts are dated to 2026-07-21. CASP16 is the latest completed round. Phase releases, unique targets, assessment units, and ligand cases use different bases and are never summed into a synthetic total.</div>}
        {benchmark.id === 'cameo' && <div class="callout"><strong>Rolling-service audit:</strong> the current platform contains one category—complex structures modeling (3D)—and has no fixed all-time total. The bounded 2024 creator-paper snapshot contains 7,150 selected targets; every live-service claim is dated to 2026-07-21 and server comparisons use common target subsets.</div>}
        {benchmark.id === 'flip' && <div class="callout"><strong>Task-unit audit:</strong> original FLIP contains 15 dataset×split tasks across AAV (7), GB1 (5), and Meltome (3). Thirteen splits are active for performance comparison; the two random Sampled splits are retained as discourse-only and never share a comparability group with active splits.</div>}
        {benchmark.id === 'flip-meltome' && <div class="callout"><strong>Human-cell count resolution:</strong> creator-paper Table 2 prints 7,156 total examples, although its 5,792 train and 1,366 test counts sum to 7,158. The pinned official CSV contains 7,158 rows, which is the registered value.</div>}
        {benchmark.id === 'proteinlmbench' && <div class="callout"><strong>Released-data audit:</strong> the current pinned JSON contains 944 questions, but only 871 have six choices; the remaining 73 have 2–5, 7, 8, or 10 choices. This conflicts with the paper's “944 six-choice questions” description. The released file also has no topical-category field, so design and binding counts remain <strong>Not reported</strong>.</div>}
        {benchmark.id === 'bioinstruction' && <div class="callout"><strong>Task and release audit:</strong> the final suite has 21 formal tasks—6 DNA, 6 RNA, 5 protein, and 4 multi-molecule—not 21 questions. Table 2's task rows sum to 243,227 test examples although its printed total is 244,681. The pinned Stage-3 workbook has 8,002 rows versus the paper's 8,000-example description, and no dataset/code license is reported.</div>}
        {benchmark.id === 'lab-bench' && <div class="callout"><strong>Category and release audit:</strong> LAB-Bench contains 2,457 questions across 8 broad categories. The pinned split manifests reproduce 1,967 public and 490 private questions across 31 task files; the official README instead says 30 narrower subtasks, so that claim remains <strong>Conflicted</strong>.</div>}
        {benchmark.id === 'genebench-pro' && <div class="callout"><strong>Release and protocol audit:</strong> the 129-problem suite is partitioned into 10 public, 50 Artificial Analysis, and 69 internal-holdout problems. All 60 reported model configurations are normalized across 13 effort/repeat groups: standard runs use 10 attempts per problem, while Claude Opus and GPT Pro (Extended) use 5. The public package's dataset card says CC BY 4.0, but its root LICENSE says MIT, so the license remains <strong>Conflicted</strong>.</div>}
        {benchmark.id === 'biomysterybench' && <div class="callout"><strong>Version and evaluation audit:</strong> the current v11 release has 90 problems (73 human-solvable, 17 human-hard) after nine removals and 24 problem edits. The April model results remain tied to v8's 99 problems (76/23), with five episodes per model–problem pair; they are never presented as v11 scores.</div>}
        {benchmark.id === 'compbiobench' && <div class="callout"><strong>Task, access, and protocol audit:</strong> v1 contains 100 tasks. The public TSV partitions them into 8 domains and 5 question styles; only one Structure task uses a protein PDB, while standalone binding counts are <strong>Not reported</strong>. Tasks and inputs are open, but the answer key and grader backend are private. Creator results are split by agent, effort, repeats, timeout policy, and the 17-task hardest subset.</div>}
        {benchmark.id === 'bixbench' && <div class="callout"><strong>Version and unit audit:</strong> the original v1.0 paper evaluated 296 questions from 53 capsules; current v1.5 has 205 questions. Upstream states 60 source notebooks/capsules, while the released rows reference 59 capsule UUIDs and the tagged tree stores 64 archives, so the 60 claim is shown as <strong>Conflicted</strong>. Exact zero-shot JSON values are registered; unlabeled agentic bars are not digitized.</div>}
        {benchmark.id === 'blade' && <div class="callout"><strong>Task-unit and protocol audit:</strong> BLADE uses 12 source research-question/dataset pairs. Its two formal tracks contain 188 MCQs (20 conceptual-variable and 168 transformation questions) and 12 end-to-end analysis tasks scored against 536 ground-truth decisions (118 conceptual-variable, 246 transformation, and 172 modeling decisions). MCQ, one-turn generation, and ReAct settings are separated; four source questions are biological or ecological, and none is a protein, binding, or omics task.</div>}
        {benchmark.id === 'scigym' && <div class="callout"><strong>Release, split, and protocol audit:</strong> SCIGYM releases 350 SBML systems: 137 small systems with fewer than ten reactions and 213 large systems with up to 400 reactions. Only the small track was evaluated in the creator paper. Its public evaluation artifact proves three episodes for every model–system pair; the code and dataset are public, but upstream states no code or data license.</div>}
        <section><p class="eyebrow">Benchmark definition</p><h2>What is counted</h2>
          <dl class="definition-list">
            <div><dt>Version</dt><dd>{benchmark.latest_version}{statusFor('/latest_version') && <StatusBadge {...statusFor('/latest_version')!} />}</dd></div>
            <div><dt>Total</dt><dd>{benchmark.task_counts.total ?? <span class="not-reported">Not reported</span>}{statusFor('/task_counts/total') && <StatusBadge {...statusFor('/task_counts/total')!} />} <span class="muted small">({benchmark.task_counts.basis})</span></dd></div>
            <div><dt>Task formats</dt><dd>{benchmark.task_formats.join('; ')}</dd></div>
            <div><dt>Capabilities</dt><dd><div class="tag-list">{benchmark.capabilities.map((id) => <Tag id={id} axis="capabilities" />)}</div></dd></div>
            <div><dt>Modalities</dt><dd><div class="tag-list">{benchmark.modalities.map((id) => <Tag id={id} axis="modalities" />)}</div></dd></div>
          </dl>
        </section>
        {benchmark.versions && benchmark.versions.length > 0 && <section class="section-tight"><h2>Version history</h2><div class="table-wrap"><table><thead><tr><th>Version</th><th>Status</th><th>Release / as-of</th><th>Total</th><th>Formal tracks</th></tr></thead><tbody>{benchmark.versions.map((version, versionIndex) => <tr><td>{version.label}<br/><code>{version.id}</code></td><td>{version.status}</td><td>{version.release_date ?? version.as_of ?? 'Not reported'}</td><td>{version.task_counts.total ?? 'Not reported'}{statusFor(`/versions/${versionIndex}/task_counts/total`) && <StatusBadge {...statusFor(`/versions/${versionIndex}/task_counts/total`)!} />} <span class="muted small">({version.task_counts.basis})</span></td><td>{version.formal_tracks.length ? version.formal_tracks.join(', ') : 'None registered'}</td></tr>)}</tbody></table></div></section>}
        {benchmark.task_counts.subsets.length > 0 && <section class="section-tight"><h2>Tracks and subsets</h2><div class="table-wrap"><table><thead><tr><th>ID</th><th>Count</th><th>Basis</th><th>Partition?</th><th>Notes</th></tr></thead><tbody>{benchmark.task_counts.subsets.map((subset, subsetIndex) => <tr><td>{subset.label}<br/><code>{subset.id}</code></td><td>{subset.count ?? 'Not reported'}{statusFor(`/task_counts/subsets/${subsetIndex}/count`) && <StatusBadge {...statusFor(`/task_counts/subsets/${subsetIndex}/count`)!} />}</td><td>{subset.basis}</td><td>{subset.exclusive && subset.exhaustive ? 'Exclusive & exhaustive' : 'No'}</td><td>{subset.notes ?? '—'}</td></tr>)}</tbody></table></div></section>}
        {children.length > 0 && <section class="section-tight"><h2>Registered child tracks</h2>{!includeChildRuns && <div class="callout info"><strong>{childRunCount} normalized runs</strong> are registered across these {children.length} tracks. Open a track for its exact split, prompt group, metrics, results, and comparison charts.</div>}<div class="grid two">{children.map((child) => <article class="card"><h3><a class="stretched" href={withBase(`/benchmarks/${child.id}/`)}>{child.name}</a></h3><p>{child.summary}</p><p class="small muted">{child.evaluation_run_ids.length} evaluation run(s)</p></article>)}</div></section>}
        <section class="section-tight"><p class="eyebrow">Scientific Task Atlas</p><h2>Scientific task classification</h2><p class="muted"><strong>{taskClassification.status}</strong> for {taskClassification.benchmark_version}{taskClassification.as_of ? ` · as of ${taskClassification.as_of}` : ''}. {taskClassification.notes}</p>
          {taskClassification.entries.length ? <div class="table-wrap"><table><thead><tr><th>Scientific task</th><th>Coverage</th><th>Count</th><th>Mapping</th><th>Evidence</th></tr></thead><tbody>{taskClassification.entries.map((entry, entryIndex) => <tr><td><Tag id={entry.task_type_id} axis="scientific_tasks" linked />{statusFor(`/scientific_task_classification/entries/${entryIndex}`) && <StatusBadge {...statusFor(`/scientific_task_classification/entries/${entryIndex}`)!} />}</td><td>{entry.coverage}</td><td class:list={{'not-reported': entry.count === null}}>{entry.count ?? 'Not reported'}{entry.count !== null && <span class="small muted"> {entry.count_unit}</span>}<br/><span class="small muted">{entry.count_basis}</span></td><td>{entry.mapping_method}<br/><span class="small muted">{entry.confidence} confidence</span></td><td>{entry.evidence_ids.map((id) => <><code>{id}</code><br/></>)}{entry.notes && <span class="small muted">{entry.notes}</span>}</td></tr>)}</tbody></table></div> : <div class="callout info">This legacy record is intentionally unclassified in the current Scientific Task Atlas.</div>}
        </section>
        {benchmark.coverage_notes.length > 0 && <section class="section-tight"><h2>Scientific coverage notes</h2><div class="table-wrap"><table><thead><tr><th>Domain</th><th>Coverage</th><th>Count</th><th>Interpretation</th></tr></thead><tbody>{benchmark.coverage_notes.map((note) => <tr><td>{termMaps.domains.get(note.tag)?.label ?? note.tag}</td><td>{note.coverage}</td><td class:list={{'not-reported': note.count === null}}>{note.count ?? 'Not reported'}</td><td>{note.notes}</td></tr>)}</tbody></table></div></section>}
        <section class="section-tight"><p class="eyebrow">Evaluation registry</p><h2>Works and run settings</h2><p class="muted">A setting change—scope, prompt, tools, budget, grader, or repeats—creates a separate run. Charts never cross a comparability group.</p>
          {runs.length ? runs.map((run) => <RunCard run={run!} />) : childRunCount > 0 ? <div class="callout info">Evaluation settings and results are published on the child-track pages above.</div> : <div class="callout info">No normalized evaluation run is published yet. Creator evidence is still attached below.</div>}
        </section>
        {resultCharts.length > 0 && <section class="section-tight"><h2>Comparable result views</h2><div class:list={{grid: true, two: resultCharts.every((chart) => chart.values.length <= 12)}}>{resultCharts.map((chart) => <PlotCard title={chart.metric.source_label} description={`${chart.run.id} · ${chart.run.comparability_group}`} kind="dot" values={chart.values} csv="/data/evaluation-results.csv" tableColumns={[{key:'label',label:'Model'},{key:'value',label:'Value'},{key:'group',label:'Comparability group'}]} options={{xLabel: chart.metric.unit, order: 'descending'}} />)}</div></section>}
        <section class="section-tight"><h2>Evidence and change history</h2><ul>{benchmark.evidence.map((evidence) => { const sourceId = evidenceSourceId(evidence); const work = sourceId ? workMap.get(sourceId) : undefined; const resource = benchmark.resources.find((item) => item.id === sourceId); return <li>{work ? <a href={withBase(`/works/${work.id}/`)}>{work.title}</a> : resource ? <a href={resource.url}>{resource.id}</a> : sourceId} — {evidenceLocator(evidence)}<br/><span class="small muted">Supports: {evidence.supports.join(', ')}</span></li>; })}</ul>{benchmark.field_status.length > 0 && <><h3>Unresolved field claims</h3><ul>{benchmark.field_status.map((status) => <li><code>{status.path}</code><StatusBadge status={status.status} confidence={status.confidence} reason={status.reason} /> — {status.reason}<br/><span class="small muted">Evidence: {status.evidence_ids.join(', ')}</span></li>)}</ul></>}<p><a href={`https://github.com/SpectrAI-Initiative/bio-benchmark-atlas/commits/main/registry/benchmarks/${benchmark.id}.yaml`}>View source-level modification history on GitHub →</a></p></section>
      </div>
      <aside class="sidebar">
        <div class="card"><p class="eyebrow">Access & reproducibility</p><dl class="definition-list">
          <div><dt>Access</dt><dd>{termMaps.access_levels.get(benchmark.access.level)?.label ?? benchmark.access.level}{statusFor('/access/level') && <StatusBadge {...statusFor('/access/level')!} />}</dd></div>
          <div><dt>Tasks</dt><dd>{benchmark.access.tasks}</dd></div><div><dt>Artifacts</dt><dd>{benchmark.access.artifacts}</dd></div><div><dt>Grader</dt><dd>{benchmark.access.grader}</dd></div><div><dt>License</dt><dd>{benchmark.access.license ?? 'Not reported'}{statusFor('/access/license') && <StatusBadge {...statusFor('/access/license')!} />}</dd></div>
        </dl></div>
        <div class="card" style="margin-top:1rem"><h3>Primary resources</h3><ul>{benchmark.resources.map((resource) => <li><a href={resource.url}>{resource.id ?? resource.type}</a>{resource.license && <span class="muted small"> · {resource.license}</span>}<br/><span class="small muted">{resource.type}{resource.pin ? ` · ${resource.pin.kind} ${resource.pin.value}` : ''}{resource.last_checked ? ` · checked ${resource.last_checked}` : ''}</span></li>)}</ul><h3>Implementations</h3><ul>{benchmark.implementations.map((impl) => <li>{impl.url ? <a href={impl.url}>{impl.framework}</a> : impl.framework}<br/><span class="small muted">{impl.status}{impl.commit ? ` · ${impl.commit.slice(0, 8)}` : ''}</span></li>)}</ul></div>
      </aside>
    </div>
  </Layout>
)}
