---
import '../styles/global.css';
import { withBase } from '../lib/data';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  lang?: string;
}

const {
  title = 'BioBench Atlas',
  description = 'A source-grounded registry of protein, omics, and life-science benchmarks and their evaluation settings.',
  canonicalPath = '/',
  lang = 'en',
} = Astro.props;
const fullTitle = title === 'BioBench Atlas' ? title : `${title} · BioBench Atlas`;
const canonical = new URL(withBase(canonicalPath), 'https://spectrai-initiative.github.io').toString();
---

<!doctype html>
<html lang={lang} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#102a43" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(withBase('/og-card.png'), 'https://spectrai-initiative.github.io').toString()} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <a class="brand" href={withBase('/')} aria-label="BioBench Atlas home">
        <span class="brand-mark" aria-hidden="true"><i></i><i></i><i></i></span>
        <span>BioBench <b>Atlas</b></span>
      </a>
      <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="primary-navigation">
        <span aria-hidden="true" class="menu-icon"><i></i><i></i><i></i></span>
        <span>Menu</span>
      </button>
      <nav id="primary-navigation" aria-label="Primary navigation">
        <a href={withBase('/benchmarks/')}>Explorer</a>
        <a href={withBase('/works/')}>Papers</a>
        <a href={withBase('/tasks/')}>Tasks</a>
        <a href={withBase('/methodology/')}>Methodology</a>
        <a href={withBase('/taxonomy/')}>Taxonomy</a>
        <a href={withBase('/archive/')}>Archive</a>
        <a href={withBase('/zh/')}>中文</a>
      </nav>
      <button class="theme-toggle" type="button" aria-label="Toggle color theme" title="Toggle color theme">
        <span aria-hidden="true">◐</span>
      </button>
    </header>
    <main id="main"><slot /></main>
    <footer>
      <div>
        <a class="brand footer-brand" href={withBase('/')}><span class="brand-mark" aria-hidden="true"><i></i><i></i><i></i></span><span>BioBench Atlas</span></a>
        <p>Source-grounded benchmark metadata. No global life-science leaderboard.</p>
      </div>
      <div class="footer-links">
        <a href={withBase('/contribute/')}>Contribute</a>
        <a href={withBase('/data/registry.json')}>Registry JSON</a>
        <a href="https://github.com/SpectrAI-Initiative/bio-benchmark-atlas">GitHub</a>
        <span>Code Apache-2.0 · Metadata CC BY 4.0</span>
      </div>
    </footer>
    <script is:inline>
      const root = document.documentElement;
      const saved = localStorage.getItem('biobench-theme');
      const initial = saved || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      root.dataset.theme = initial;
      document.querySelector('.theme-toggle')?.addEventListener('click', () => {
        const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
        root.dataset.theme = next;
        localStorage.setItem('biobench-theme', next);
      });

      const header = document.querySelector('.site-header');
      const menuButton = document.querySelector('.menu-toggle');
      const navigation = document.querySelector('#primary-navigation');
      const mobileMenu = matchMedia('(max-width: 900px)');
      const closeMenu = (restoreFocus = false) => {
        if (!header || !menuButton) return;
        header.removeAttribute('data-menu-open');
        menuButton.setAttribute('aria-expanded', 'false');
        if (restoreFocus) menuButton.focus();
      };
      const openMenu = () => {
        if (!header || !menuButton || !navigation) return;
        header.setAttribute('data-menu-open', '');
        menuButton.setAttribute('aria-expanded', 'true');
        navigation.querySelector('a')?.focus({ preventScroll: true });
      };
      menuButton?.addEventListener('click', () => {
        if (menuButton.getAttribute('aria-expanded') === 'true') closeMenu();
        else openMenu();
      });
      navigation?.addEventListener('click', (event) => {
        if (event.target instanceof HTMLAnchorElement && mobileMenu.matches) closeMenu();
      });
      document.addEventListener('click', (event) => {
        if (mobileMenu.matches && header?.hasAttribute('data-menu-open') && event.target instanceof Node && !header.contains(event.target)) closeMenu();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && header?.hasAttribute('data-menu-open')) closeMenu(true);
      });
      mobileMenu.addEventListener('change', () => closeMenu());

      document.querySelectorAll('.detail-grid .table-wrap').forEach((tableWrap) => {
        if (!(tableWrap instanceof HTMLElement) || tableWrap.parentElement?.classList.contains('table-scroll-shell')) return;
        const shell = document.createElement('div');
        shell.className = 'table-scroll-shell';
        const hint = document.createElement('span');
        hint.className = 'table-scroll-hint';
        hint.textContent = 'Swipe to view more';
        hint.setAttribute('aria-hidden', 'true');
        tableWrap.before(shell);
        shell.append(tableWrap, hint);
        const updateOverflow = () => {
          const overflows = tableWrap.scrollWidth > tableWrap.clientWidth + 2;
          shell.toggleAttribute('data-overflow', overflows);
          shell.toggleAttribute('data-scrolled', tableWrap.scrollLeft > 8);
          if (overflows) {
            tableWrap.setAttribute('tabindex', '0');
            tableWrap.setAttribute('role', 'region');
            const sectionHeading = tableWrap.closest('section')?.querySelector('h2, h3')?.textContent?.trim();
            tableWrap.setAttribute('aria-label', `${sectionHeading || 'Data'} table`);
          } else {
            tableWrap.removeAttribute('tabindex');
            tableWrap.removeAttribute('role');
            tableWrap.removeAttribute('aria-label');
          }
        };
        tableWrap.addEventListener('scroll', updateOverflow, { passive: true });
        new ResizeObserver(updateOverflow).observe(tableWrap);
        updateOverflow();
      });
    </script>
  </body>
</html>
