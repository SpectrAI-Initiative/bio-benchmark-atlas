---
import Layout from '../../components/Layout.astro';
import RunCard from '../../components/RunCard.astro';
import UseCard from '../../components/UseCard.astro';
import { benchmarkMap, data, withBase } from '../../lib/data';
export function getStaticPaths() { return data.works.map((work) => ({ params: { id: work.id }, props: { work } })); }
const { work } = Astro.props;
const runs = data.evaluation_runs.filter((run) => run.work_id === work.id);
const uses = data.benchmark_uses.filter((use) => use.work_id === work.id);
const currentSource = work.source_versions.find((version) => version.id === work.current_version_id);
const visibleAuthors = work.authors.slice(0, 5);
const remainingAuthors = work.authors.slice(5);
---
<Layout title={work.title} canonicalPath={`/works/${work.id}/`}>
  <header class="page-head page-head--compact work-head shell"><div class="breadcrumbs"><a href={withBase('/')}>Atlas</a><span>/</span><a href={withBase('/works/')}>Papers</a><span>/</span><span>Work detail</span></div><p class="eyebrow">{work.work_type} · {work.source_class.replaceAll('_',' ')}</p><h1>{work.title}</h1><p class="lede">{work.organizations.join(' · ')} · {work.publication_date}</p></header>
  <div class="shell section detail-grid"><div>
    <section><p class="eyebrow">Relationship layer</p><h2>Benchmark usage</h2><p class="muted">This table records what the work did with each benchmark before attempting to normalize a run. Partial claims remain visible without being treated as comparable evaluations.</p>{uses.length ? uses.map((use) => <UseCard use={use} showWork={false} />) : <div class="callout info">No BenchmarkUse relation is normalized for this legacy work yet. Existing EvaluationRuns remain available below.</div>}</section>
    <section class="section-tight"><h2>Normalized evaluation runs</h2>{runs.length ? runs.map((run) => <><p><a href={withBase(`/benchmarks/${run.benchmark_id}/`)}>{benchmarkMap.get(run.benchmark_id)?.name ?? run.benchmark_id} →</a></p><RunCard run={run} /></>) : <div class="callout info">This source has no normalized model run. It may be a creator-only source or a partial/non-evaluation benchmark use.</div>}</section>
  </div>
  <aside class="sidebar card"><h3>Source record</h3><dl class="definition-list"><div><dt>Status</dt><dd>{work.status}</dd></div><div><dt>Published</dt><dd>{work.publication_date}</dd></div><div><dt>Authors</dt><dd>{visibleAuthors.join(', ') || 'Not reported'}{remainingAuthors.length > 0 && <details class="author-overflow"><summary>and {remainingAuthors.length} more</summary><p>{remainingAuthors.join(', ')}</p></details>}</dd></div><div><dt>DOI</dt><dd>{work.doi ?? 'Not reported'}</dd></div><div><dt>arXiv</dt><dd>{work.arxiv ?? 'Not reported'}</dd></div><div><dt>Current source version</dt><dd><code>{work.current_version_id}</code></dd></div>{currentSource?.source_access && <div><dt>Source access</dt><dd>{currentSource.source_access}</dd></div>}{currentSource?.content_sha256 && <div><dt>Content SHA256</dt><dd><code class="fingerprint">{currentSource.content_sha256}</code></dd></div>}{currentSource?.retrieved_at && <div><dt>Retrieved</dt><dd>{currentSource.retrieved_at}</dd></div>}</dl>
  {work.review_provenance && <><h3>Review provenance</h3><p><span class="usage-badge normalized">AI-assisted</span> <span class="usage-badge normalized">owner-reviewed</span></p><dl class="definition-list compact"><div><dt>Method</dt><dd>{work.review_provenance.method}</dd></div><div><dt>Pipeline</dt><dd><code>{work.review_provenance.pipeline_version}</code></dd></div><div><dt>Prompt</dt><dd><code>{work.review_provenance.prompt_version}</code></dd></div><div><dt>Extractor</dt><dd>{work.review_provenance.extractor_model_resolved}<br/><span class="small muted">requested {work.review_provenance.extractor_model_requested}</span></dd></div><div><dt>Verifier</dt><dd>{work.review_provenance.verifier_model_resolved}<br/><span class="small muted">requested {work.review_provenance.verifier_model_requested}</span></dd></div><div><dt>Generated</dt><dd>{work.review_provenance.generated_at}</dd></div></dl><p class="small muted">“Owner-reviewed” means this production record passed the required post-push approval gate; the model never merged or authored Registry YAML directly.</p></>}
  <h3>Source versions</h3><ul>{work.source_versions.map((version) => <li><a href={version.canonical_url}>{version.label}</a><br/><span class="small muted">{version.id} · {version.status} · {version.publication_date}</span></li>)}</ul><p><a class="button" href={work.canonical_url}>Open canonical source ↗</a></p></aside></div>
</Layout>
