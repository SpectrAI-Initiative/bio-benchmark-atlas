---
import Layout from '../../components/Layout.astro';
import { data } from '../../lib/data';
---
<Layout title="中文 Taxonomy" canonicalPath="/zh/taxonomy/" lang="zh-CN"><header class="page-head shell"><p class="eyebrow">多轴受控词表</p><h1>同一个 benchmark 可以有多个科学坐标。</h1><p class="lede">Domain 表示科学范围，Capability 表示要完成的能力，Modality 表示输入，Access 表示开放程度。</p></header><div class="shell section"><h2>Domain / 科学领域</h2><div class="grid three">{data.taxonomies.domains.map((term) => <article class="card"><code>{term.id}</code><h3>{term.label_zh}</h3><p>{term.label} · {term.definition}</p></article>)}</div></div></Layout>
